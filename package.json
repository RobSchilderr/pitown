{
	"name": "pitown-workspace",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"engines": {
		"node": ">=24"
	},
	"packageManager": "pnpm@10.29.3",
	"scripts": {
		"build": "turbo build",
		"clean": "turbo clean && rm -rf node_modules",
		"link:global": "pnpm build && pnpm --dir packages/cli link --global",
		"lint": "turbo lint",
		"pitown": "tsx packages/cli/src/index.ts",
		"release": "node scripts/release.mjs",
		"release:github": "node scripts/release.mjs --github",
		"syncpack:check": "syncpack lint",
		"syncpack:fix": "syncpack fix-mismatches && syncpack format",
		"test": "turbo test",
		"town:doctor": "tsx packages/cli/src/doctor.ts",
		"town:run": "tsx packages/cli/src/run.ts",
		"town:status": "tsx packages/cli/src/status.ts",
		"town:watch": "tsx packages/cli/src/watch.ts",
		"typecheck": "turbo typecheck",
		"version:check": "node scripts/version-packages.mjs --check",
		"version:major": "node scripts/version-packages.mjs major",
		"version:minor": "node scripts/version-packages.mjs minor",
		"version:patch": "node scripts/version-packages.mjs patch"
	},
	"devDependencies": {
		"@eslint/js": "9.39.3",
		"@ianvs/prettier-plugin-sort-imports": "4.7.1",
		"@types/node": "25.3.0",
		"eslint": "9.39.3",
		"eslint-config-prettier": "10.1.2",
		"eslint-plugin-only-warn": "1.1.0",
		"eslint-plugin-turbo": "2.5.0",
		"prettier": "3.8.1",
		"syncpack": "13.0.4",
		"tsdown": "0.20.3",
		"tsx": "4.21.0",
		"turbo": "2.8.10",
		"typescript": "5.9.2",
		"typescript-eslint": "8.46.0",
		"vitest": "4.0.18"
	},
	"bugs": "https://github.com/RobSchilderr/pitown/issues",
	"description": "Pi Town monorepo workspace",
	"homepage": "https://github.com/RobSchilderr/pitown#readme",
	"license": "MIT",
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"rolldown",
			"unrs-resolver"
		]
	},
	"repository": "RobSchilderr/pitown.git"
}
